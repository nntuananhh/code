<Window x:Class="Giai_PTB2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Giai_PTB2"
        mc:Ignorable="d"
        Title="GIẢI PHƯƠNG TRÌNH BẬC 2"
        WindowStartupLocation="CenterScreen"
        MinWidth="720"
        MinHeight="520"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1A2A6C" Offset="0"/>
            <GradientStop Color="#3B5BDB" Offset="0.5"/>
            <GradientStop Color="#7858FF" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Margin" Value="0,8,0,8"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#1F2A4E"/>
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="BorderBrush" Value="#D3D9EE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <ScrollViewer Margin="0" x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#3F7DFF" Offset="0"/>
                        <GradientStop Color="#825BFF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#5B92FF" Offset="0"/>
                                <GradientStop Color="#A07BFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#5C68FF"
                                              BlurRadius="18"
                                              ShadowDepth="0"
                                              Opacity="0.35"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.92"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Border CornerRadius="32"
                Padding="26"
                Margin="24"
                Background="#F9FBFF"
                Effect="{DynamicResource DropShadowEffectResource}">
            <Border.Resources>
                <DropShadowEffect x:Key="DropShadowEffectResource"
                                  Color="#2E356B"
                                  BlurRadius="28"
                                  ShadowDepth="0"
                                  Opacity="0.18"/>
            </Border.Resources>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="GIẢI PHƯƠNG TRÌNH BẬC 2"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="#1F2A4E"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,18"/>

                <Border Grid.Row="1"
                        CornerRadius="24"
                        Background="#FFFFFF"
                        Padding="24"
                        Margin="0,0,0,20"
                        BorderBrush="#E4E9F5"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Hệ số a"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#4A597D"
                                   Margin="0,4,0,0"
                                   Grid.Row="0"
                                   Grid.Column="0"/>
                        <TextBox x:Name="InputA"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 PreviewTextInput="NumericTextBox_PreviewTextInput"
                                 DataObject.Pasting="NumericTextBox_Pasting"
                                 Grid.Row="0"
                                 Grid.Column="1"/>

                        <TextBlock Text="Hệ số b"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#4A597D"
                                   Margin="0,4,0,0"
                                   Grid.Row="1"
                                   Grid.Column="0"/>
                        <TextBox x:Name="InputB"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 PreviewTextInput="NumericTextBox_PreviewTextInput"
                                 DataObject.Pasting="NumericTextBox_Pasting"
                                 Grid.Row="1"
                                 Grid.Column="1"/>

                        <TextBlock Text="Hệ số c"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#4A597D"
                                   Margin="0,4,0,0"
                                   Grid.Row="2"
                                   Grid.Column="0"/>
                        <TextBox x:Name="InputC"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 PreviewTextInput="NumericTextBox_PreviewTextInput"
                                 DataObject.Pasting="NumericTextBox_Pasting"
                                 Grid.Row="2"
                                 Grid.Column="1"/>
                    </Grid>
                </Border>

                <Button x:Name="SolveButton"
                        Grid.Row="2"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Content="Giải phương trình"
                        Click="SolveButton_Click"
                        HorizontalAlignment="Center"
                        Width="260"
                        Margin="0,0,0,20"/>

                <Border Grid.Row="3"
                        CornerRadius="22"
                        Background="#F4F7FF"
                        Padding="24"
                        BorderBrush="#E4E7F6"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Kết quả"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#1F2A4E"
                                   Margin="0,0,0,14"/>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                            <TextBlock Text="Delta:" FontSize="15" FontWeight="SemiBold" Foreground="#4A597D"/>
                            <TextBlock x:Name="DeltaTextBlock"
                                       Text="-"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#2D3F6F"
                                       Margin="8,0,0,0"/>
                        </StackPanel>

                        <TextBlock Text="Thông báo nghiệm:" FontSize="15" FontWeight="SemiBold" Foreground="#4A597D" Margin="0,8,0,6"/>
                        <TextBlock x:Name="SolutionTextBlock"
                                   Text="Nhập hệ số và nhấn Giải phương trình để xem nghiệm."
                                   FontSize="16"
                                   TextWrapping="Wrap"
                                   Foreground="#263153"
                                   LineHeight="24"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
